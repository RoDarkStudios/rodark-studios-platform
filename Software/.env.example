AUTH_SECRET=generate-a-long-random-secret
ROBLOX_OAUTH_CLIENT_ID=your-roblox-oauth-client-id
ROBLOX_OAUTH_CLIENT_SECRET=your-roblox-oauth-client-secret
# Optional: defaults to current origin + /api/auth/callback
# ROBLOX_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/callback
# Optional: defaults to "openid profile"
# ROBLOX_OAUTH_SCOPES=openid profile
# Optional: defaults to https://apis.roblox.com/oauth
# ROBLOX_OAUTH_BASE_URL=https://apis.roblox.com/oauth
# Optional: group id used for admin tab visibility (rank >= 254)
# ROBLOX_GROUP_ID=5545660
# Required for admin monetization/config tools
# Must include scopes: game-pass:read, game-pass:write, developer-product:read, developer-product:write, universe:read, universe:write, universe.place:write
# Add universe.ordered-data-store.scope.entry:read when Discord leaderboard role sync is enabled.
ROBLOX_OPEN_CLOUD_API_KEY=your-roblox-open-cloud-api-key

# Required for shared admin Game Configuration storage on Railway Postgres.
DATABASE_URL=postgresql://user:password@host:port/database

# Required on the web service for Discord dashboard lookups.
# Required on the separate 24/7 Discord bot Railway service for all bot actions.
DISCORD_BOT_TOKEN=your-discord-bot-token
# Required on the Discord bot worker to review ticket requests before opening channels.
OPENAI_API_KEY=your-openai-api-key
# Optional: defaults to gpt-5.5.
# OPENAI_TICKET_REVIEW_MODEL=gpt-5.5
# Optional: defaults to medium.
# OPENAI_TICKET_REVIEW_REASONING_EFFORT=medium
# Optional: defaults to 15000.
# OPENAI_TICKET_REVIEW_TIMEOUT_MS=15000
# Optional: set if the dashboard cannot infer the guild from configured channel IDs.
# DISCORD_BOT_GUILD_ID=your-discord-server-id

# Required only when Discord leaderboard role sync is enabled.
# Get this from the Bloxlink Developer Portal for your Discord server/guild.
BLOXLINK_API_KEY=your-bloxlink-guild-api-key
# Optional: defaults to https://api.blox.link/v4
# BLOXLINK_API_BASE_URL=https://api.blox.link/v4
# Optional: defaults to 10
# BLOXLINK_LOOKUP_CACHE_TTL_MINUTES=10
# Optional: defaults to 10 lookups with a 750ms delay to avoid Bloxlink rate limits
# BLOXLINK_LOOKUPS_PER_SYNC=10
# BLOXLINK_LOOKUP_DELAY_MS=750
# BLOXLINK_RATE_LIMIT_BACKOFF_MS=300000
